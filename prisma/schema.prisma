generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  LEARNER
  INSTRUCTOR
}

enum Transmission {
  MANUAL
  AUTOMATIC
  BOTH
}

enum BookingStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AdiStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               Role
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  twoFactorBackupCodes   String[] @default([])

  // When set, the account is scheduled for permanent deletion at this time
  // (30-day grace period). The account is locked and hidden until then; the
  // user can restore it by signing in before the date.
  deletionScheduledFor DateTime?

  learnerProfile    LearnerProfile?
  instructorProfile InstructorProfile?
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model LearnerProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postcode     String
  transmission Transmission @default(MANUAL)
  goal         String?

  // The learner's current instructor — at most one at a time. Null = unattached.
  activeInstructorId String?
  activeInstructor   InstructorProfile? @relation("Roster", fields: [activeInstructorId], references: [id], onDelete: SetNull)

  bookings Booking[]

  joinRequests JoinRequest[]
  messages     Message[]
  reviews      Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeInstructorId])
}

model InstructorProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adiNumber    String // DVSA ADI badge number
  businessName String?
  postcodes    String // comma-separated coverage areas for now
  transmission Transmission @default(MANUAL)
  hourlyRate   Int // whole pounds per hour
  carDetails   String?
  bio          String?

  // ADI verification (manual admin review against the DVSA register)
  adiStatus     AdiStatus @default(PENDING)
  adiReviewedAt DateTime?
  adiBadgeUrl   String?

  // Roster + invites
  inviteCode              String?  @unique // reusable join-link token, generated lazily
  acceptingStudents       Boolean  @default(true) // instructor's own availability toggle
  cancellationNoticeHours Int      @default(48) // instructor-set notice window
  slug                    String?  @unique // SEO-friendly profile URL
  photoUrl                String? // public profile photo (Vercel Blob URL)

  // Stripe subscription (billing). Synced from Stripe webhooks; Stripe is the
  // source of truth — these are a local mirror for gating + display.
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // trialing | active | past_due | unpaid | canceled | incomplete...
  subscriptionPriceId  String? // which Stripe price (founder vs standard)
  isFounder            Boolean   @default(false) // locked founder rate
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime? // end of current paid period / trial — drives grace + renewal display
  cancelAtPeriodEnd    Boolean   @default(false)

  roster   LearnerProfile[] @relation("Roster")
  bookings Booking[]

  joinRequests   JoinRequest[]
  expenses       Expense[]
  messages       Message[]
  reviews        Review[]
  theoryFeedback TheoryFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  start        DateTime
  durationMins Int           @default(60)
  status       BookingStatus @default(BOOKED)
  pricePence   Int? // snapshot of the agreed price; optional until payments land
  paid         Boolean       @default(false)
  notes        String?
  cancelledAt  DateTime?
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([learnerId])
  @@index([start])
}

model JoinRequest {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  status  JoinRequestStatus @default(PENDING)
  message String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instructorId, learnerId])
  @@index([instructorId, status])
  @@index([learnerId])
}

model Expense {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  date        DateTime
  amountPence Int
  category    String
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId, date])
}

model Message {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  senderId     String // User.id of the sender (instructor or learner)
  body         String
  readAt       DateTime?
  createdAt    DateTime          @default(now())

  @@index([instructorId, learnerId, createdAt])
}

model Review {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  rating       Int // 1–5
  body         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([instructorId, learnerId])
  @@index([instructorId])
}

// Instructor (ADI) feedback on theory questions — used to QA the in-house bank.
model TheoryFeedback {
  id           String             @id @default(cuid())
  questionId   String
  instructorId String?
  instructor   InstructorProfile? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  comment      String
  resolved     Boolean            @default(false)
  createdAt    DateTime           @default(now())

  @@index([questionId])
  @@index([resolved])
}

// B2B outreach CRM — prospecting driving instructors to invite onto the platform.
model Prospect {
  id              String    @id @default(cuid())
  name            String
  area            String?
  phone           String?
  email           String?
  website         String?
  googlePlaceId   String?   @unique
  source          String    @default("places") // places, manual, referral
  status          String    @default("NEW") // NEW, CONTACTED, REPLIED, DEMO, SIGNED_UP, NOT_INTERESTED, DO_NOT_CONTACT
  rating          Float?
  notes           String?
  unsubscribeToken String?  @unique
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  emails OutreachEmail[]

  @@index([status])
}

// One outreach email per prospect, drafted by the agent and sent after approval.
model OutreachEmail {
  id         String    @id @default(cuid())
  prospectId String
  prospect   Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  subject    String
  body       String
  status     String    @default("DRAFT") // DRAFT, SENT, FAILED
  resendId   String?
  error      String?
  sentAt     DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  bouncedAt     DateTime?
  complainedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([prospectId])
  @@index([status])
}
