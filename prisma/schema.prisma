generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  LEARNER
  INSTRUCTOR
}

enum Transmission {
  MANUAL
  AUTOMATIC
  BOTH
}

enum BookingStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AdiStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               Role
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  learnerProfile    LearnerProfile?
  instructorProfile InstructorProfile?
}

model LearnerProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postcode     String
  transmission Transmission @default(MANUAL)
  goal         String?

  // The learner's current instructor — at most one at a time. Null = unattached.
  activeInstructorId String?
  activeInstructor   InstructorProfile? @relation("Roster", fields: [activeInstructorId], references: [id], onDelete: SetNull)

  bookings Booking[]

  joinRequests JoinRequest[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeInstructorId])
}

model InstructorProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adiNumber    String // DVSA ADI badge number
  businessName String?
  postcodes    String // comma-separated coverage areas for now
  transmission Transmission @default(MANUAL)
  hourlyRate   Int // whole pounds per hour
  carDetails   String?
  bio          String?

  // ADI verification (manual admin review against the DVSA register)
  adiStatus     AdiStatus @default(PENDING)
  adiReviewedAt DateTime?
  adiBadgeUrl   String?

  // Roster + invites
  inviteCode              String?  @unique // reusable join-link token, generated lazily
  acceptingStudents       Boolean  @default(true) // instructor's own availability toggle
  cancellationNoticeHours Int      @default(48) // instructor-set notice window

  roster   LearnerProfile[] @relation("Roster")
  bookings Booking[]

  joinRequests JoinRequest[]
  expenses     Expense[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  start        DateTime
  durationMins Int           @default(60)
  status       BookingStatus @default(BOOKED)
  pricePence   Int? // snapshot of the agreed price; optional until payments land
  paid         Boolean       @default(false)
  notes        String?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([learnerId])
  @@index([start])
}

model JoinRequest {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  status  JoinRequestStatus @default(PENDING)
  message String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instructorId, learnerId])
  @@index([instructorId, status])
  @@index([learnerId])
}

model Expense {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  date        DateTime
  amountPence Int
  category    String
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId, date])
}

model Message {
  id           String            @id @default(cuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  learnerId    String
  learner      LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  senderId     String // User.id of the sender (instructor or learner)
  body         String
  readAt       DateTime?
  createdAt    DateTime          @default(now())

  @@index([instructorId, learnerId, createdAt])
}
