# --- Neon Postgres (Pro) ---
# Pooled connection (app runtime). Note the "-pooler" in the host.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Direct connection (used by Prisma for migrations). No "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Auth.js v5 ---
# Generate one with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-secret"

# Comma-separated admin emails (ADI verification, etc.)
ADMIN_EMAILS=

# --- Feature flags ---
# Block bookings / prepaid credit. Hidden unless set to exactly "true".
# Requires FCA-aware legal sign-off before enabling in production.
BLOCK_BOOKINGS_ENABLED=
